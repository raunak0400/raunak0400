{
  "builds": [
    {
      "src": "api/orchestrator.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/redirect",
      "dest": "https://open.spotify.com/user/raunak0400",
      "status": 302
    },
    {
      "src": "/(.*)",
      "dest": "api/orchestrator.py"
    }
  ]
}